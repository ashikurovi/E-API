{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "api/index.ts", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] }
  ]
}
